# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # server-only (PDF route / admin). NEVER expose to client.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PDF export — signs short-lived tokens for the cookie-less /proposals/[id]/print render target.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PDF_SIGNING_SECRET=

# AI — Areas of Opportunity generation from a call transcript (server-only).
ANTHROPIC_API_KEY=

# OpenAI — Whisper transcription for .m4a call recordings (server-only).
OPENAI_API_KEY=
